{
  "compression_zone": {
    "d_model": 768,
    "d_state": 192,
    "groups": 4,
    "layers_per_group": 6,
    "mamba_layers_per_group": 5,
    "retrieval_layers_per_group": 1,
    "ffn_dim": 3072,
    "block_repr_every_n_layers": 3,
    "block_repr_count": 8,
    "swa_window": 1024,
    "kda_no_fox": true,
    "mamba_mimo_enabled": true,
    "mamba_complex_state_enabled": true,
    "mamba_post_gate_rmsnorm_required": true
  },
  "reason_loop": {
    "loops_min": 1,
    "loops_max": 8,
    "slow_k": 2,
    "meta_dim": 96,
    "c_t_dim": 64,
    "reason_ffn_dim": 3072,
    "swa_window": 1024,
    "exit_threshold": 0.85,
    "know_gap_threshold": 0.7,
    "router_dim": 256
  },
  "mhc": {
    "n_streams": 4,
    "apply_zone": "reason_loop_only",
    "sinkhorn_iters": 20,
    "alpha_init": 0.01,
    "state_layout": "B_T_N_C",
    "dynamic_maps_from": "current_stream_state",
    "residual_constraint": "birkhoff_doubly_stochastic"
  },
  "loss": {
    "lm_weight": 1.0,
    "world_weight": 0.1,
    "self_weight": 0.03,
    "rollout_weight": 0.01,
    "residual_reg_weight": 0.001,
    "rollout_steps": 2,
    "self_target": "delta_c_t",
    "world_target": "masked_latent_prediction"
  },
  "gate": {
    "stagnation_k": 3,
    "delta_h_threshold": 0.015,
    "c_t_cos_low": 0.7,
    "c_t_cos_high": 0.95
  },
  "stage0_harness": {
    "seed": 42,
    "batch_size": 1,
    "seq_len": 128,
    "device": "cuda",
    "dtype": "bfloat16",
    "out_metrics_file": "artifacts/stage0_metrics.jsonl"
  }
}